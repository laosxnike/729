SITE_URL=https://your-vercel-domain.vercel.app

# Existing Stripe account values. Use test keys first, then live keys.
STRIPE_SECRET_KEY=sk_test_or_live_xxx
STRIPE_SUCCESS_URL=https://your-vercel-domain.vercel.app/success.html
STRIPE_CANCEL_URL=https://your-vercel-domain.vercel.app/shop.html

# Publish Google Sheet tabs as CSV and paste the public CSV URLs here.
PRODUCTS_CSV_URL=
EVENTS_CSV_URL=
PRACTITIONERS_CSV_URL=

# Optional fallback if you do not want products in a sheet yet.
# JSON object where each site id maps to an existing Stripe Price ID.
# Example: {"s1":"price_123","s2":"price_456","e10":"price_789"}
PRODUCT_PRICE_MAP={}
EVENT_PRICE_MAP={}
PRACTITIONER_PRICE_MAP={}

# Webhook URLs can be Google Apps Script, Zapier, Make, Airtable, etc.
RESERVATION_WEBHOOK_URL=
PRACTITIONER_INTAKE_WEBHOOK_URL=
PRACTITIONER_BOOKING_WEBHOOK_URL=
CONTACT_WEBHOOK_URL=
